{
  "name": "swarm-orchest-ia",
  "version": "0.1.0",
  "description": "Multi-Agent SDD Orchestrator CLI — manages project setup for Spec-Driven Development",
  "main": "dist/cmd/swarm.js",
  "bin": {
    "swarm": "./dist/cmd/swarm.js"
  },
  "files": [
    "dist/",
    "templates/"
  ],
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "ts-node src/cmd/swarm.ts",
    "start": "node dist/cmd/swarm.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "swarm",
    "sdd",
    "opencode",
    "agents",
    "spec-driven"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "inquirer": "^13.4.2",
    "js-yaml": "^4.1.1",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
