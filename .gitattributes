# Normalize line endings: store as LF in the repo, check out native on each OS.
* text=auto eol=lf

# Explicit text files
*.ts    text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf

# Binary files (never normalize)
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
